# PostgreSQL connection string (Neon, or any Postgres)
# Neon: https://neon.tech → create project → copy connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DATABASE_SSL="true" # "true" for remote Postgres (rejectUnauthorized:false)

# ── NextAuth v5 (Auth.js) ─────────────────────────────────────────────────────
# v5 reads AUTH_SECRET automatically. Generate with: openssl rand -base64 32
AUTH_SECRET="run: openssl rand -base64 32"
# Behind a proxy in prod, also set: AUTH_TRUST_HOST=true

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
#                          (local: http://localhost:3002/api/auth/callback/google)
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# Restrict login to a single owner email (fail-closed if unset).
# OWNER_EMAIL is preferred; ALLOWED_EMAIL is accepted as a fallback.
OWNER_EMAIL="your@email.com"

# Legacy owner UUID used as diagrams.user_id so existing diagrams keep resolving.
# Find it once via: SELECT DISTINCT user_id FROM diagrams;
OWNER_USER_ID="00000000-0000-0000-0000-000000000000"

# Secret token for the AI diagram creation API (POST /api/ai/diagrams) and
# Bearer-authorized script access. Generate with: openssl rand -base64 32
AI_API_SECRET="your-secret-token-here"

# Anthropic key for POST /api/ai/generate
ANTHROPIC_API_KEY="sk-ant-..."
